{
  "title": "Resource",
  "type": "object",
  "required": [
    "resourceId",
    "resourceType",
    "displayName",
    "ownerPrincipalId",
    "sensitivity",
    "lifecycleState",
    "createdAt",
    "updatedAt",
    "source"
  ],
  "properties": {
    "resourceId": {
      "type": "string"
    },
    "resourceType": {
      "enum": [
        "MEMORY",
        "WORLD_MODEL",
        "DOCUMENT",
        "EMAIL",
        "CALENDAR",
        "CONTACT",
        "HOME_ASSISTANT_ENTITY",
        "ANDROID_CAPABILITY",
        "TOOL",
        "PLUGIN",
        "AGENT",
        "SECRET",
        "CONFIGURATION",
        "AUDIT_LOG",
        "SESSION",
        "EVENT",
        "TASK",
        "WORKFLOW"
      ]
    },
    "displayName": {
      "type": "string"
    },
    "ownerPrincipalId": {
      "type": "string"
    },
    "sensitivity": {
      "enum": [
        "PUBLIC",
        "PERSONAL",
        "HOUSEHOLD",
        "FINANCIAL",
        "MEDICAL",
        "LEGAL",
        "SECURITY_SENSITIVE",
        "CREDENTIALS_SECRETS",
        "THIRD_PARTY_PERSONAL_DATA"
      ]
    },
    "lifecycleState": {
      "enum": [
        "CREATED",
        "REGISTERED",
        "AVAILABLE",
        "UPDATED",
        "ARCHIVED",
        "DELETED"
      ]
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "source": {
      "type": "string",
      "description": "Where this Resource originated (e.g. the subsystem or Plugin that created it). Required by Resource.md and src/contracts/Resource.kt; previously missing from this schema."
    },
    "metadata": {
      "type": "object"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema"
}
