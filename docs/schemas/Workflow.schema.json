{
  "title": "Workflow",
  "type": "object",
  "required": [
    "workflowId",
    "ownerPrincipalId",
    "status",
    "steps",
    "createdAt"
  ],
  "properties": {
    "workflowId": {
      "type": "string"
    },
    "ownerPrincipalId": {
      "type": "string"
    },
    "status": {
      "enum": [
        "CREATED",
        "ACTIVE",
        "RUNNING",
        "PAUSED",
        "COMPLETED",
        "FAILED",
        "CANCELLED",
        "ARCHIVED"
      ]
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "metadata": {
      "type": "object"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema"
}