{
  "title": "Principal",
  "type": "object",
  "required": [
    "principalId",
    "principalType",
    "displayName",
    "owner",
    "status",
    "createdAt",
    "lastSeenAt"
  ],
  "properties": {
    "principalId": {
      "type": "string"
    },
    "principalType": {
      "enum": [
        "USER",
        "SYSTEM",
        "INTERNAL_AGENT",
        "PLUGIN",
        "TOOL",
        "SCHEDULED_TASK",
        "DEVELOPER_SESSION",
        "FUTURE_REMOTE_DEVICE"
      ]
    },
    "displayName": {
      "type": "string"
    },
    "owner": {
      "type": [
        "string",
        "null"
      ]
    },
    "status": {
      "enum": [
        "CREATED",
        "ACTIVE",
        "SUSPENDED",
        "REVOKED",
        "ARCHIVED"
      ]
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "lastSeenAt": {
      "type": "string",
      "format": "date-time"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema"
}
